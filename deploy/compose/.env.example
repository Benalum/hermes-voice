HERMES_AGENT_IMAGE=nousresearch/hermes-agent:latest
HERMES_VOICE_IMAGE=hermes-voice:portable

# Use the private address of hermes-speech. Do not publish CT101 through Serve or Funnel.
HERMES_SPEECH_URL=http://192.168.0.201:9000
HERMES_SPEECH_TIMEOUT_SECONDS=180
HERMES1_SPEECH_CLIENT_ID=hermes1
HERMES1_SPEECH_TOKEN=replace-with-hermes1-64-hex-token
HERMES1_TTS_VOICE=af_heart
HERMES1_TTS_SPEED=1.0
HERMES2_SPEECH_CLIENT_ID=hermes2
HERMES2_SPEECH_TOKEN=replace-with-hermes2-64-hex-token
HERMES2_TTS_VOICE=af_heart
HERMES2_TTS_SPEED=1.0

HERMES1_VOICE_PORT=8991
HERMES2_VOICE_PORT=8992

# Optional: required only with `docker compose --profile tailscale up`.
HERMES1_TS_HOSTNAME=hermes1-voice
HERMES1_TS_AUTHKEY=
HERMES2_TS_HOSTNAME=hermes2-voice
HERMES2_TS_AUTHKEY=
